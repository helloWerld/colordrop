# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Postgres URI for migrations. Use the pooler URI (host contains pooler.supabase.com), not the direct db.*.supabase.co one.
# Supabase Dashboard → Database → Connection string → "Use connection pooling" → URI (port 6543).
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Image conversion: Gemini (Nano Banana) primary, Replicate fallback. At least one required.
GEMINI_API_KEY=...
# Replicate is used when Gemini is not set or fails (fallback).
REPLICATE_API_TOKEN=r8_...
# Optional: set to true to use FLUX Kontext Pro (Try for Free collection, limited runs, no payment). Weaker line-art result.
# REPLICATE_USE_FREE_MODEL=true

# Stripe — live (production) keys when STRIPE_USE_SANDBOX is not true
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# Dashboard or Stripe CLI signing secret for live mode webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — sandbox (test) keys when STRIPE_USE_SANDBOX=true (same pattern as LULU_USE_SANDBOX). Restart after toggling.
# STRIPE_USE_SANDBOX=true
# STRIPE_SANDBOX_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test_...
# Test mode: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` → paste whsec_ into STRIPE_SANDBOX_WEBHOOK_SECRET
# STRIPE_SANDBOX_WEBHOOK_SECRET=whsec_...

# Lulu (production)
LULU_CLIENT_KEY=your-client-key
LULU_CLIENT_SECRET=your-client-secret
LULU_API_BASE_URL=https://api.lulu.com

# Lulu sandbox (testing). LULU_USE_SANDBOX=true uses sandbox keys and URL only when LULU_SANDBOX_* are set; otherwise production Lulu is used if LULU_CLIENT_KEY / LULU_CLIENT_SECRET are set. Restart to switch.
# Get sandbox keys at https://developers.sandbox.lulu.com/user-profile/api-keys
# LULU_USE_SANDBOX=false
# LULU_SANDBOX_CLIENT_KEY=your-sandbox-client-key
# LULU_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret
# LULU_SANDBOX_API_BASE_URL=https://api.sandbox.lulu.com

# Optional: representative US address for Lulu cost calculations (used to cache book prices).
# LULU_COST_CALC_STREET1=101 Independence Ave SE
# LULU_COST_CALC_CITY=Washington
# LULU_COST_CALC_STATE=DC
# LULU_COST_CALC_POSTCODE=20540
# LULU_COST_CALC_COUNTRY=US
# LULU_COST_CALC_PHONE=+12065550100

# Book pricing: percent markup on Lulu print+fulfillment vs shipping (default 50 each). Change and restart to apply.
BOOK_MARKUP_PERCENT=50
SHIPPING_MARKUP_PERCENT=50

# Resend
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=https://colordrop.ai
# Optional: shown on order details and similar for “Contact support” mailto links
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
